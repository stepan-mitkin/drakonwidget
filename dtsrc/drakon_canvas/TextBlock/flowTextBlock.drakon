      "content": "line.width = line.right - line.left"
    },
    "37": {
      "type": "action",
      "one": "38",
      "content": "last = line.tokens[\n    line.tokens.length - 1\n]"
    },
    "38": {
      "flag1": 0,
      "type": "question",
      "one": "36",
      "two": "39",
      "content": "last.type === \"space\""
