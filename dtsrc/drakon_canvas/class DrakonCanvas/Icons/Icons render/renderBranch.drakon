    "14": {
      "type": "action",
      "one": "15",
      "content": "x = node.x\ny = node.y\nw = node.w\nh = node.h\nbottom = y + h\ntx0 = x - w / 2;\ntx1 = x + w / 2;\nty = (bottom + middle) / 2;"
    },
    "15": {
      "type": "action",
      "one": "17",
      "content": "ctx.fillStyle = visuals.config.theme.internalLine"
    },
    "16": {
