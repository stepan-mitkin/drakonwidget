      "type": "action",
      "two": "",
      "content": "ctx.fill()"
    },
    "17": {
      "type": "action",
      "one": "16",
      "content": "ctx.beginPath()\nctx.moveTo(tx0, ty)\nctx.lineTo(x, bottom)\nctx.lineTo(tx1, ty)\nctx.closePath()"
    },
    "21": {
      "type": "action",
      "one": "27",
      "content": "tri = visuals.config.triangleHeight"
    },
