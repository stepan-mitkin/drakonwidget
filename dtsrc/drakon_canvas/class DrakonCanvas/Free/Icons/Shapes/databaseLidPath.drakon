    "3": {
      "type": "action",
      "one": "6",
      "content": "h2 = makeCylinderHeight(w)\nscale = h / h2\nctop = y - h2 + w"
    },
    "4": {
      "one": "5",
      "type": "action",
      "two": "",
      "content": "h = height / 2\nw = width / 2"
    },
    "5": {
      "one": "3",
      "type": "action",
      "two": "",
      "content": "x = left + w\ny = top + h"
    },
    "6": {
      "type": "action",
      "one": "1",
      "content": "ctx.save()\nctx.translate(x, y)\nctx.scale(1, scale)\nctx.translate(-x, -y)\nctx.beginPath();\nctx.arc(x, ctop, w, 0, Math.PI)\nctx.restore()"
    }
  },
