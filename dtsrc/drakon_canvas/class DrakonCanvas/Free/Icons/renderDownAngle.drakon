    "8": {
      "type": "action",
      "one": "1",
      "content": "padding = w * 0.3\ny0 = y - h / 3\ny1 = y + h / 3\nx0 = x - w + padding\nx1 = x + w - padding\nline2(ctx, x0, y0, x, y1, x1, y0)"
    }
  },
