      "type": "action",
      "two": "",
      "content": "handle = RoundedRadius()"
    },
    "5": {
      "one": "9",
      "type": "action",
      "two": "",
      "content": "setCommonHandleFields(\n    widget,\n    element,\n    handle\n)"
    },
    "6": {
      "one": "3",
      "type": "action",
      "two": "",
      "content": "createHandle(visuals, handle, ctx)"
    },
    "7": {
      "one": "8",
      "type": "action",
      "two": "",
      "content": "handle.x = right - element.aux - touch\n* 2\nhandle.y = element.top\nhandle.minX = element.left + touch * 2\nhandle.maxX = right - touch * 2"
    },
    "8": {
      "one": "12",
      "type": "action",
      "two": "",
      "content": "handle.right = right\nhandle.touch = touch\nhandle.color = \"yellow\""
    },
    "9": {
      "one": "10",
      "type": "action",
      "two": "",
      "content": "right = element.left + element.width"
    },
    "10": {
      "one": "7",
      "type": "action",
      "two": "",
      "content": "touch = visuals.config.socketTouchRadius"
    },
    "11": {
      "type": "action",
      "one": "4",
      "content": "visuals = widget.visuals"
    },
    "12": {
      "type": "action",
      "one": "6",
      "content": "handle.primId = \"radius-\" + element.id"
    }
