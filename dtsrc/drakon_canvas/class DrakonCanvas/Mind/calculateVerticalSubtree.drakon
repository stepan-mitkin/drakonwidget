      "content": "Adjust box"
    },
    "42": {
      "flag1": 0,
      "type": "question",
      "two": "47",
      "one": "54",
      "content": "nLeft < 0"
    },
    "46": {
      "type": "action",
      "one": "42",
      "content": "nLeft = node.x - node.w\nnRight = node.x + node.w"
    },
    "47": {
      "type": "action",
      "one": "48",
      "content": "shift = -nLeft"
    },
    "48": {
      "one": "50",
