      "content": "child.subtreeBox.left += shift"
    },
    "51": {
      "type": "action",
      "one": "54",
      "content": "width += shift\nnode.x += shift\nnRight += shift"
    },
    "52": {
      "type": "action",
      "one": "38",
      "content": "node.subtreeBox.height = bottom"
    },
    "54": {
      "type": "action",
      "one": "10",
      "content": "node.subtreeBox.width = Math.max(\n    nRight,\n    width\n)"
    },
