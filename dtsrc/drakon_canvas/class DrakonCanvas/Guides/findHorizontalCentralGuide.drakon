            "content": "ebox.centerY === y"
        },
        "13": {
            "type": "action",
            "one": "17",
            "content": "left = Math.min(left, ebox.centerX)\nright = Math.max(right, ebox.centerX)"
        },
        "15": {
            "branchId": 3,
