      "two": "53",
      "content": "model.branches.length === 0"
    },
    "22": {
      "type": "action",
      "one": "23",
      "content": "end = createNewItem(model, \"end\")\nbranch = createNewItem(model, \"branch\")"
    },
    "23": {
