      "content": "branch.branchId = 0\nbranch.one = end.id"
    },
    "24": {
      "type": "action",
      "one": "39",
      "content": "diagram.initial.push(createInsert(end))\ndiagram.initial.push(\n    createInsert(branch)\n)"
