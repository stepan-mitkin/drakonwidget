      "type": "action",
      "one": "6",
      "content": "header = visuals.header\nparams = visuals.params\nlevel = header.level\nhx = getX(header)\nhy = getY(header)"
    },
    "6": {
      "type": "action",
      "one": "7",
      "content": "x = hx + header.w + metre + params.w"
    },
    "7": {
