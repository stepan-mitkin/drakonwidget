      "type": "question",
      "two": "8",
      "one": "9",
      "content": "params.h > header.h"
    },
    "8": {
      "type": "action",
      "one": "10",
      "content": "delta = params.h - header.h\ny = hy - delta"
    },
    "9": {
      "type": "action",
      "one": "10",
      "content": "y = hy"
    },
    "10": {
      "type": "action",
      "one": "11",
      "content": "level.coord = y\nskewer.coord = x"
    },
    "11": {
      "type": "action",
      "one": "12",
      "content": "params.level = level\nparams.skewer = skewer"
    },
    "12": {
      "type": "action",
