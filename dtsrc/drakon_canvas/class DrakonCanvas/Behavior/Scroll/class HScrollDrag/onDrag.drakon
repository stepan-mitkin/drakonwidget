    "4": {
      "one": "1",
      "type": "action",
      "two": "",
      "content": "setScrollFromMouseEvent(self.widget, x, y)"
    },
    "5": {
      "one": "4",
      "type": "action",
      "two": "",
      "content": "x = self.startScrollX - deltaX / zoom\ny = self.startScrollY - deltaY / zoom"
    },
    "6": {
      "one": "7",
      "type": "action",
      "two": "",
      "content": "deltaX = (self.startX - evt.clientX) * self\n.barToBox\ndeltaY = 0"
    },
    "7": {
      "one": "5",
      "type": "action",
      "two": "",
      "content": "zoom = self.widget.zoomFactor"
    }
